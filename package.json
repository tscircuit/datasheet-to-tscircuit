{
  "name": "datasheet-to-tscircuit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Turn component datasheets into previewable tscircuit TSX with tsci-agent",
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"bun --watch src/server/index.ts\" \"vite\"",
    "dev:server": "bun --watch src/server/index.ts",
    "dev:web": "vite",
    "build": "docker compose build",
    "build:web": "vite build",
    "start": "docker compose up --no-build",
    "start:server": "bun src/server/index.ts",
    "stop": "docker compose down",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:docker": "sh scripts/docker-smoke-test.sh",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "bun run typecheck && bun test && bun run build:web"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@resvg/resvg-js": "^2.6.2",
    "@tscircuit/3d-viewer": "^0.0.577",
    "@tscircuit/assembly-viewer": "^0.0.6",
    "@tscircuit/core": "^0.0.1467",
    "@tscircuit/create-snippet-url": "^0.0.15",
    "@tscircuit/internal-dynamic-import": "^0.0.11",
    "@tscircuit/ngspice-spice-engine": "^0.0.19",
    "@tscircuit/pcb-viewer": "1.11.375",
    "@tscircuit/runframe": "0.0.2227",
    "@tscircuit/schematic-viewer": "^2.0.73",
    "class-variance-authority": "^0.7.1",
    "circuit-json": "0.0.450",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "debug": "^4.4.0",
    "fflate": "^0.8.2",
    "fuse.js": "^7.1.0",
    "jszip": "^3.10.1",
    "ky": "^1.7.5",
    "lucide-react": "latest",
    "marked": "^15.0.12",
    "posthog-js": "^1.253.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-error-boundary": "^6.0.0",
    "react-hot-toast": "^2.5.2",
    "react-query": "^3.39.3",
    "tailwind-merge": "^2.6.0",
    "tsci-agent": "0.1.10",
    "tscircuit": "0.0.2110",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@types/bun": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "concurrently": "latest",
    "typescript": "^5.9.3",
    "vite": "latest"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.9"
}
